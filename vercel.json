{
  "version": 2,
  "buildCommand": "echo 'Static site'",
  "outputDirectory": ".",
  "public": true,
  "env": {},
  "routes": [
    {
      "src": "/universal-api-client.html",
      "dest": "/universal-api-client.html",
      "methods": ["GET", "HEAD"]
    },
    {
      "src": "/(.*)",
      "dest": "/universal-api-client.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/html; charset=utf-8"
        }
      ]
    }
  ]
}
